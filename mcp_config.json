{
  "mcpServers": {
    "spec-governance": {
      "command": "python",
      "args": ["./mcp/spec-governance/server.py"],
      "env": {
        "SPEC_ROOT": "./docs",
        "SCORING_SPEC": "./docs/klaritypm_assess_scoring.md"
      }
    },
    "template-library": {
      "command": "python",
      "args": ["./mcp/template-library/server.py"],
      "env": {
        "TEMPLATE_ROOT": "./templates"
      }
    },
    "schema-and-data": {
      "command": "python",
      "args": ["./mcp/schema-and-data/server.py"],
      "env": {
        "SCHEMA_ROOT": "./db",
        "SEED_ROOT": "./seed"
      }
    },
    "test-and-regression": {
      "command": "python",
      "args": ["./mcp/test-and-regression/server.py"],
      "env": {
        "TEST_ROOT": "./tests",
        "SNAPSHOT_ROOT": "./tests/snapshots"
      }
    },
    "design-system": {
      "command": "python",
      "args": ["./mcp/design-system/server.py"],
      "env": {
        "DESIGN_ROOT": "./design-system"
      }
    }
  }
}