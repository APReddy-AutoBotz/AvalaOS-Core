{
  "name": "avalaos-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:requirements && npm run test:delivery-policy && npm run test:govern-lite && npm run test:delivery-pack && npm run test:ai-boundary",
    "test:requirements": "node scripts/runScoringRegression.mjs",
    "test:scoring": "node scripts/runScoringRegression.mjs",
    "test:delivery-policy": "node scripts/runTypeScriptTest.mjs services/deliveryPolicy.ts services/deliveryPolicy.test.ts",
    "test:govern-lite": "node scripts/runTypeScriptTest.mjs services/avalaGovernLiteService.ts services/assessmentExportService.ts services/avalaGovernLiteService.test.ts",
    "test:delivery-pack": "node scripts/runTypeScriptTest.mjs services/avalaGovernLiteService.ts services/deliveryPackService.ts services/deliveryPackExportService.ts services/deliveryPackService.test.ts",
    "test:ai-boundary": "node scripts/runTypeScriptTest.mjs types.ts services/aiMode.ts services/aiMode.test.ts",
    "test:ai-boundary-static": "node scripts/check-ai-boundary.mjs",
    "test:supabase:delivery": "node scripts/supabaseDeliverySmoke.mjs",
    "test:supabase:delivery-roles": "node scripts/supabaseDeliveryRoleSmoke.mjs",
    "test:rls:assess": "node scripts/applySupabaseMigrations.mjs docs/schema/rls_regression_assess_handoff.sql",
    "db:migrate": "node scripts/applySupabaseMigrations.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
